\f3\fs26 \cf0 Which regions have the highest supply chain disruptions?\
\pard\pardeftab720\sa240\partightenfactor0

\f0\b\fs24 \cf0 Generated SQL:
\f1\b0 \
\pard\pardeftab720\partightenfactor0

\f3\fs26 \cf0 SELECT region, COUNT(*) AS disruption_count\
FROM supply_chain_data\
WHERE disruption_flag = 1\
GROUP BY region\
ORDER BY disruption_count DESC;\
